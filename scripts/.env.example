# ai-tryon 配置文件
# cp .env.example .env  然后填入 Key

# ── 即梦 AI（火山引擎）— 图像 & 视频优先使用 ─────────────
# 注册：https://console.volcengine.com → 访问控制 → 密钥管理
# 图像模型：jimeng_t2i_v40 | 视频模型：jimeng_ti2v_v30_pro
# 配置了即梦后，图片和视频均优先走即梦，豆包作为降级备选
JIMENG_ACCESS_KEY=
JIMENG_SECRET_KEY=

# ── 豆包 Seedream 生图 / Seedance 生视频（火山方舟）────
# 注册：https://console.volcengine.com/ark
ARK_API_KEY=
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
ARK_IMAGE_MODEL=doubao-seedream-5-0-260128
ARK_VIDEO_MODEL_PRO=doubao-seedance-1-5-pro-251215
ARK_VIDEO_MODEL_LITE=doubao-seedance-1-0-lite-i2v-250428

# ── 阿里云百炼 AI试衣（国内直连）───────────────────────
# 注册：https://bailian.aliyun.com → 选「中国内地（北京）」地域
ALIYUN_API_KEY=sk-

# ── OSS 图床（本地图片上传用）──────────────────────────
# 注册：https://oss.console.aliyun.com
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
OSS_BUCKET_NAME=your-bucket-name
OSS_ENDPOINT=oss-cn-hangzhou.aliyuncs.com
OSS_PREFIX=ai-tryon/
OSS_CDN_DOMAIN=

# ── 备用方案（可选）────────────────────────────────────
# DALL·E 3（需代理）
OPENAI_API_KEY=sk-
OPENAI_BASE_URL=https://api.openai.com/v1  # 走代理时改为代理地址
# Claude（生成变体 prompt 用）
ANTHROPIC_API_KEY=sk-ant-
# Fashn.ai（海外试衣，需代理）
FASHN_API_KEY=fa-
# IDM-VTON via Replicate（海外，需代理，非商业）
REPLICATE_API_TOKEN=r8_
# remove.bg 去背景（50次/月免费）
REMOVEBG_API_KEY=

# ── 输出目录 ────────────────────────────────────────────
# 所有生成的图片和视频保存的根目录
# 默认：运行终端当前目录（pwd）下的 tryon_output/
# 建议改为固定绝对路径，避免因切换目录导致文件散落
# 例：TRYON_OUTPUT_DIR=/Users/xxx/Desktop/tryon_output
TRYON_OUTPUT_DIR=
